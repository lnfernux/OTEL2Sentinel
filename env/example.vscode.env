# VS Code Copilot telemetry export example
# Set these in your shell before launching VS Code.

COPILOT_OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://<collector-fqdn>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <shared-secret>
OTEL_SERVICE_NAME=copilot-chat

# Keep content capture disabled by default.
COPILOT_OTEL_CAPTURE_CONTENT=false

# Optional resource tags for filtering in Azure Monitor.
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev,team.id=platform
